ELEVENLABS_API_KEY=
SEALION_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# STT
STT_LANGUAGE_CODE=my
ELEVENLABS_STT_MODEL_ID=scribe_v2_realtime

# VAD
VAD_BACKEND=energy  # energy | silero_vad_lite

# Set to "0" to require real providers.
USE_MOCK_SERVICES=1

# SEA-LION tuning (optional)
LLM_TIMEOUT_MS=600
LLM_TOKEN_TIMEOUT_MS=2500
LLM_FALLBACK_TIMEOUT_MS=2500
SEALION_MODEL=aisingapore/Gemma-SEA-LION-v4-27B-IT
SEALION_FALLBACK=aisingapore/Llama-SEA-LION-v3-70B-IT
SEALION_BASE_URL=https://api.sea-lion.ai/v1
SEALION_CONNECT_TIMEOUT_MS=1500
SEALION_READ_TIMEOUT_MS=3000

# Azure TTS tuning (optional)
TTS_VOICE=my-MM-NilarNeural
TTS_RATE=+5%
TTS_PITCH=+0Hz
TTS_TIMEOUT_MS=4000
TTS_FLUSH_MAX_CHARS=240
TTS_FLUSH_MAX_DELAY_MS=5000
TTS_FLUSH_MODE=sentence  # sentence | turn | hybrid
